# Copia este archivo como `.env` (no se comitea) y completa los valores.
#
# IMPORTANTE: No es seguro distribuir llaves/secretos en apps cliente (Android/iOS/Web).
# Para producción, usa un backend/proxy o un mecanismo seguro.

# Groq (OpenAI-compatible)
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant

